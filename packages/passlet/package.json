{
  "name": "passlet",
  "version": "0.2.0",
  "type": "module",
  "description": "Generate Apple Wallet and Google Wallet passes from a single API",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke": "tsx --env-file=.env scripts/smoke.ts",
    "prepack": "cp ../../README.md README.md"
  },
  "dependencies": {
    "jose": "^5.9.6",
    "jszip": "^3.10.1",
    "node-forge": "^1.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@passlet/config": "workspace:*",
    "@types/node-forge": "^1.3.11",
    "tsup": "^8.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}

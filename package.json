{
  "name": "passlet",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@types/react": "^19.2.17",
      "@types/react-dom": "^19.2.3",
      "dotenv": "^17.4.2",
      "lucide-react": "^1.17.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.7",
      "react-dom": "^19.2.7",
      "sonner": "^2.0.7",
      "tailwindcss": "^4.3.0",
      "zod": "^4.4.3"
    }
  },
  "type": "module",
  "scripts": {
    "clean": "git clean -xdf node_modules",
    "clean:workspaces": "turbo clean",
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "turbo build --filter=passlet && changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@passlet/config": "workspace:*",
    "@types/node": "^20.19.42",
    "lefthook": "latest",
    "turbo": "^2.9.16",
    "typescript": "^6.0.3",
    "ultracite": "7.8.2"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "packageManager": "pnpm@10.33.0"
}
